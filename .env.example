"""
Environment configuration template.

Copy this file to .env and fill in your Azure credentials.
"""

# Azure Document Intelligence (OCR and Layout Extraction)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<your-region>.api.cognitive.microsoft.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=<your-api-key>

# Azure OpenAI (GPT-4o and Embeddings)
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-large

# Vector Database
FAISS_INDEX_PATH=./data/faiss_index.bin
METADATA_PATH=./data/metadata.json
EMBEDDING_DIMENSION=3072

# Document Processing
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MAX_IMAGE_WIDTH=1024
MAX_IMAGE_HEIGHT=1024

# API Server
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
